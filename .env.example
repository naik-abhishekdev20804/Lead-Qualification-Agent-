# ============================================================
# Lead Qualification AI — Environment Configuration
# Copy this file to `.env` and fill in your real keys.
# The `.env` file is git-ignored. NEVER commit real keys.
# ============================================================

# --- Gemini (required) ---
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Model used by all agents (override if you hit quota limits)
GEMINI_MODEL=gemini-2.5-flash

# --- Web research providers (required for live research) ---
# Tavily: https://tavily.com  (primary web search — multi-query deep research)
TAVILY_API_KEY=

# Serper: https://serper.dev  (fallback Google search if Tavily fails)
SERPER_API_KEY=

# Firecrawl: https://firecrawl.dev  (website scraping — scrapes discovered real URLs)
FIRECRAWL_API_KEY=

# --- API budget protection (see MASTER.md) ---
# When TRUE, external API tools return canned mock data — zero API calls.
# Set FALSE + add Tavily/Firecrawl keys above for real-time company research.
MOCK_MODE=FALSE

# Disk cache TTL in hours (research results are cached to avoid repeat calls)
CACHE_TTL_HOURS=24

# Max external API calls allowed per provider per day (hard stop)
DAILY_API_BUDGET=50

# --- App settings ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Research output format controls (UI-friendly lengths) ---
RESEARCH_OVERVIEW_MAX_CHARS=650
RESEARCH_NEWS_MAX_CHARS=700
RESEARCH_DETAILED_SUMMARY_MAX_CHARS=2800
RESEARCH_MAX_GROWTH_SIGNALS=6
RESEARCH_MAX_TECH_STACK=10
RESEARCH_MAX_SOURCES=10

# --- Gmail real send (used by Approve & send button) ---
# Enable only when ready to send real email to your demo inbox.
GMAIL_SEND_ENABLED=TRUE
GMAIL_DEMO_TO_EMAIL=mitecollege123@gmail.com
GMAIL_SENDER_EMAIL=
GMAIL_SUBJECT_PREFIX=[LeadPilot Demo]

# Paths can be relative to project root.
GMAIL_CREDENTIALS_FILE=secrets/gmail_credentials.json
GMAIL_TOKEN_FILE=secrets/gmail_token.json
